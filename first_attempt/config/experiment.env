# Shared experiment config — sourced by both runners (Option 1 shell + Option 2 python).
# Fill in BASE_URL and AUTH_TOKEN after `databricks auth login` (see README, Open Item 1).
#
# Both options MUST use the same model id so "same model + version" holds by construction.

# Databricks-hosted Anthropic Messages API. Use the plain FMAPI path, or the
# /ai-gateway/anthropic path if the workspace uses Unity AI Gateway.
export ANTHROPIC_BASE_URL="https://adb-984752964297111.11.azuredatabricks.net/serving-endpoints/anthropic"

# Same version Claude Code uses natively (server reports it as claude-opus-4-8).
export ANTHROPIC_MODEL="databricks-claude-opus-4-8"

# Fresh OAuth token from the field-eng-east profile each time this file is sourced.
export DATABRICKS_PROFILE="field-eng-east"
export ANTHROPIC_AUTH_TOKEN="$(databricks auth token -p field-eng-east | python3 -c 'import sys,json;print(json.load(sys.stdin)["access_token"])')"

# Required by Databricks for coding-agent traffic.
export ANTHROPIC_CUSTOM_HEADERS="x-databricks-use-coding-agent-mode: true"

# Pin every Claude Code model alias to the same Databricks model (Option 1 only).
export ANTHROPIC_DEFAULT_OPUS_MODEL="databricks-claude-opus-4-8"
export ANTHROPIC_DEFAULT_SONNET_MODEL="databricks-claude-opus-4-8"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="databricks-claude-opus-4-8"
export ANTHROPIC_SMALL_FAST_MODEL="databricks-claude-opus-4-8"
export CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS="1"

# Local mock account service.
export MOCK_API_PORT="8723"
